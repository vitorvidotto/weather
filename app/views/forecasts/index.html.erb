<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-300 via-blue-200 to-blue-100 p-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h1 class="text-blue-900 text-center text-2xl font-bold mb-2">Weather Forecast</h1>
      <p class="text-gray-500 text-center text-sm mb-8">Enter your address to get the latest weather forecast</p>

      <%= form_with url: forecast_path, method: :get, class: "space-y-6" do |f| %>
        <% if alert %>
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">
            <%= alert %>
          </div>
        <% end %>

        <div>
          <%= f.label :address, "Address", class: "block text-sm text-gray-700 mb-2" %>
          <%= f.text_field :address,
              placeholder: "Enter city or ZIP code",
              class: "w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all",
              autofocus: true %>
        </div>

        <%= f.submit "Get Forecast", class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
