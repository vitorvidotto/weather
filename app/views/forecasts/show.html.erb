<div class="min-h-screen bg-gray-50 p-4">
  <div class="max-w-2xl mx-auto">

    <%# Top bar %>
    <div class="flex items-center justify-between mb-6 pt-2">
      <%= link_to root_path, class: "flex items-center gap-2 text-blue-600 hover:text-blue-700 transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        <span>New Search</span>
      <% end %>

      <% if @payload[:from_cache] %>
        <div class="px-3 py-1 bg-amber-100 text-amber-700 rounded-full text-sm">
          Cached. Last updated <%= time_ago_in_words(@payload[:cached_at]) %> ago
        </div>
      <% else %>
        <div class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">
          Live. Fetched just now
        </div>
      <% end %>
    </div>

    <%# Current conditions card %>
    <div class="bg-white rounded-2xl shadow-md p-6 mb-4">
      <div class="mb-4">
        <h2 class="text-blue-900 text-xl font-bold"><%= @result.location %></h2>
        <p class="text-gray-500 text-sm">ZIP <%= @result.zip_code %></p>
      </div>

      <div class="flex items-start justify-between mb-6">
        <div>
          <div class="text-6xl text-blue-900 mb-1"><%= @result.current.temp_f.round %>°F</div>
          <div class="text-gray-500 text-sm mb-2"><%= @result.current.temp_c.round %>°C</div>
          <div class="text-gray-700"><%= @result.current.condition %></div>
        </div>
        <div class="mt-2">
          <img src="https:<%= @result.current.icon %>" alt="<%= @result.current.condition %>" class="w-16 h-16">
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4 pt-4 border-t border-gray-100 text-center">
        <div>
          <div class="text-gray-500 text-sm mb-1">Feels Like</div>
          <div class="text-blue-900 font-medium"><%= @result.current.feels_like_f.round %>°F</div>
        </div>
        <div>
          <div class="text-gray-500 text-sm mb-1">Humidity</div>
          <div class="text-blue-900 font-medium"><%= @result.current.humidity %>%</div>
        </div>
        <div>
          <div class="text-gray-500 text-sm mb-1">Wind</div>
          <div class="text-blue-900 font-medium"><%= @result.current.wind_mph %> mph</div>
        </div>
      </div>
    </div>

    <%# 3-day forecast card %>
    <div class="bg-white rounded-2xl shadow-md p-6">
      <h3 class="text-blue-900 font-bold mb-4">3-Day Forecast</h3>

      <div class="space-y-0">
        <% @result.forecast.each_with_index do |day, i| %>
          <div class="flex items-center justify-between py-3 <%= i < @result.forecast.length - 1 ? 'border-b border-gray-100' : '' %>">
            <div class="flex items-center gap-4 flex-1">
              <div class="w-24 text-gray-700"><%= i == 0 ? "Today" : day.date.strftime("%A") %></div>
              <img src="https:<%= day.icon %>" alt="<%= day.condition %>" class="w-8 h-8 flex-shrink-0">
              <div class="flex-1">
                <div class="text-gray-700 text-sm"><%= day.condition %></div>
                <div class="text-sm text-blue-600 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a8 8 0 00-8 8c0 3.866 2.754 7.08 6.406 7.799L10 18l1.594-.201C15.246 17.08 18 13.866 18 10a8 8 0 00-8-8z" clip-rule="evenodd"/></svg>
                  <%= day.chance_of_rain %>%
                </div>
              </div>
            </div>
            <div class="text-right">
              <div class="text-blue-900 font-medium"><%= day.high_f.round %>°</div>
              <div class="text-gray-500 text-sm"><%= day.low_f.round %>°</div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
